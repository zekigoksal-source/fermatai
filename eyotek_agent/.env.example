# ============================================================
# FermatAI — Ortam Değişkenleri
# Kullanım: Bu dosyayı .env olarak kopyala, değerleri doldur.
#   cp .env.example .env
# ============================================================


# ── Eyotek LMS ───────────────────────────────────────────────
# Eyotek site base URL (trailing slash olmadan)
EYOTEK_URL=https://fermat.eyotek.com/v1

# Chrome DevTools Protocol port (Chrome --remote-debugging-port ile açılır)
CDP_PORT=9222

# Session cookie dosyası (otomatik oluşturulur, elle düzenleme gerekmez)
SESSION_FILE=.eyotek_session.json


# ── PostgreSQL ───────────────────────────────────────────────
# Tam bağlantı URL'i
# Örnek: postgresql://user:pass@localhost:5432/fermatai
DATABASE_URL=postgresql://postgres:password@localhost:5432/fermatai


# ── Anthropic / Claude ───────────────────────────────────────
# Claude API anahtarı — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Pedagojik muhakeme için kullanılacak model
# Önerilen: claude-sonnet-4-6 (derin analiz) veya claude-haiku-4-5-20251001 (hız)
FERMAT_MODEL=claude-sonnet-4-6


# ── OpenAI (opsiyonel — Whisper ses transkripsiyon) ──────────
# Boş bırakılırsa Anthropic multimodal ASR fallback kullanılır
OPENAI_API_KEY=sk-...


# ── WhatsApp Business API ────────────────────────────────────
# Meta Developer Portal → WhatsApp → Configuration'dan alınır

# Webhook doğrulama için seçtiğin gizli token
WA_VERIFY_TOKEN=fermatai_verify_2026

# System User Access Token (uzun ömürlü, en az 60 gün)
WA_ACCESS_TOKEN=EAAxxxxx...

# Meta'dan alınan Phone Number ID (sayısal)
WA_PHONE_NUMBER_ID=123456789012345

# App Secret — webhook imza doğrulaması için (opsiyonel, geliştirmede boş bırakılabilir)
WA_APP_SECRET=


# ── WhatsApp Bridge Sunucu ───────────────────────────────────
# uvicorn port (varsayılan 8000)
BRIDGE_PORT=8000

# Geliştirme modunda --reload aktif olur
DEV_MODE=false

# FermatAI Production .env Template
# =====================================================
# VPS'te /opt/fermatai/.env olarak kopyala, değerleri doldur
# chmod 600 .env (sadece owner okur)
#
# NOT: Bu dosya TEMPLATE — gerçek değerleri LAPTOP'taki .env'den kopyala
# =====================================================

# ─── LLM Providers ────────────────────────────────────────
ANTHROPIC_API_KEY=                          # Claude Sonnet 4.5
GROQ_API_KEY=                               # Groq Llama 70B (YENİ, eklenecek)
OPENAI_API_KEY=                             # Whisper ASR (sesli mesaj)
FERMAT_MODEL=claude-sonnet-4-5
OLLAMA_URL=                                 # Boş bırak, VPS'te Ollama kurulu değil
OLLAMA_MODEL=                               # Boş bırak
OLLAMA_TIMEOUT=                             # Boş bırak
LLM_PROVIDER=hybrid_with_groq               # YENİ provider modu

# ─── Database ──────────────────────────────────────────────
# Docker compose ile PostgreSQL kurulduysa host=localhost
DATABASE_URL=postgresql://fermat:CHANGEME@localhost:5432/fermatai
REDIS_URL=redis://localhost:6379/0

# ─── Bridge ────────────────────────────────────────────────
BRIDGE_PORT=8001
AGENT_API_KEY=                              # Kendin üret: openssl rand -hex 32

# ─── WhatsApp (Meta) ──────────────────────────────────────
WA_ACCESS_TOKEN=                            # Meta Developer → Token
WA_PHONE=
WA_PHONE_NUMBER_ID=
WA_BUSINESS_ACCOUNT_ID=
WA_VERIFY_TOKEN=                            # Webhook verify — sabit kalsın
FB_APP_ID=
FB_APP_SECRET=

# ─── Admin ─────────────────────────────────────────────────
ADMIN_PHONE=905051256802                    # Neo (Zeki Göksal)

# ─── Eyotek (VPS auto-login + CapSolver Turnstile solver) ─
EYOTEK_USER=                                # Eyotek kullanıcı adı (ornegin: 1003zeki)
EYOTEK_PASS=                                # Eyotek sifre
EYOTEK_URL=https://fermat.eyotek.com/v1
SESSION_FILE=/opt/fermatai/.eyotek_session.json
EYOTEK_SESSION_ENABLED=true                 # true -> session_keeper aktif (HTTP heartbeat)
HEADLESS=true                               # VPS'te headless zorunlu (ekran yok)

# CapSolver Turnstile auto-solve (Oturum 25.6 — Talimat #85)
# https://capsolver.com -> hesap ac -> $5 yukle -> API Keys -> kopyala
# ~$0.001/cozum (haftada 2-3 CAPTCHA -> ayda ~$0.05)
# Bu anahtar olmadan Eyotek Cloudflare gecilmez -> sistem manuel login bekler
CAPSOLVER_API_KEY=                          # CAP-xxxxxxxxxxxxx...

# ─── Google Calendar ──────────────────────────────────────
GCAL_CALENDAR_ID=
GCAL_SERVICE_ACCOUNT_JSON=/opt/fermatai/gcal-service-account.json

# ─── YouTube ──────────────────────────────────────────────
YOUTUBE_API_KEY=

# ─── Domain + SSL (production) ───────────────────────────
# Ngrok kullanılmıyor — sabit domain
PRODUCTION_DOMAIN=api.fermategitimkurumlari.com
# NGROK_* variables artık gerekli değil (silinecek)

# ─── Environment ─────────────────────────────────────────
ENV=production
DEBUG=false
LOG_LEVEL=INFO

# ─── Groq Config (YENİ) ──────────────────────────────────
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile  # Ana model (Llama 70B)
GROQ_MODEL_FAST=llama-3.1-8b-instant        # Hızlı basit işler
GROQ_MAX_RETRIES=2
GROQ_TIMEOUT_SEC=30

# ─── Bütçe Korumaları ────────────────────────────────────
CLAUDE_DAILY_LIMIT=300                      # Günde 300 Claude mesaj max
GROQ_DAILY_LIMIT=2000                       # Günde 2000 Groq mesaj max
COST_ALERT_THRESHOLD_USD=10                 # Günlük $10 aşarsa admin'e bildir
